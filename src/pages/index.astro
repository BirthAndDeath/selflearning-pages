<!doctype html>
<html>
    <head>
        <meta charset="utf-8" />
        <title>Redirecting...</title>
        <style>
            body {
                font-family:
                    -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
                    sans-serif;
                display: flex;
                justify-content: center;
                align-items: center;
                min-height: 100vh;
                margin: 0;
                background-color: #f8f9fa;
                color: #333;
            }
            .container {
                text-align: center;
                padding: 2rem;
                max-width: 500px;
            }
            .spinner {
                display: inline-block;
                width: 40px;
                height: 40px;
                border: 4px solid #e9ecef;
                border-top-color: #0066cc;
                border-radius: 50%;
                animation: spin 0.8s linear infinite;
            }
            @keyframes spin {
                to {
                    transform: rotate(360deg);
                }
            }
            .message {
                margin-top: 1.5rem;
                font-size: 1.1rem;
                line-height: 1.6;
            }
            .countdown {
                margin-top: 1rem;
                font-size: 0.95rem;
                color: #666;
            }
            .unsupported {
                color: #856404;
                background-color: #fff3cd;
                padding: 0.75rem 1.25rem;
                border-radius: 8px;
                margin-top: 1rem;
                font-size: 0.95rem;
            }
        </style>
    </head>
    <body>
        <div class="container">
            <div class="spinner"></div>
            <div class="message" id="message">
                Redirecting to your preferred language...
            </div>
            <div class="countdown" id="countdown"></div>
        </div>

        <script>
            // ✅ 配置支持语言和对应的路径
            const SUPPORTED_LOCALES = [
                { code: "zh-CN", path: "/zh-cn/" },
                { code: "en", path: "/en/" },
            ];

            const DEFAULT_LOCALE = "/en/";

            // 获取浏览器首选语言
            const userLang =
                navigator.language || navigator.languages?.[0] || "en";

            // 匹配逻辑：精确匹配 -> 前缀匹配 -> 默认
            function getMatchedPath(lang: string) {
                // 1. 精确匹配
                const exactMatch = SUPPORTED_LOCALES.find(
                    (locale) =>
                        locale.code.toLowerCase() === lang.toLowerCase(),
                );
                if (exactMatch) {
                    return { path: exactMatch.path, matched: true };
                }

                // 2. 前缀匹配
                const prefix = lang.split("-")[0];
                const prefixMatch = SUPPORTED_LOCALES.find((locale) =>
                    locale.code.toLowerCase().startsWith(prefix),
                );
                if (prefixMatch) {
                    return { path: prefixMatch.path, matched: true };
                }

                // 3. 未匹配
                return { path: DEFAULT_LOCALE, matched: false };
            }

            const result = getMatchedPath(userLang);

            // 如果匹配成功，直接跳转
            if (result.matched) {
                window.location.replace(result.path);
            } else {
                // 未匹配：显示提示，3秒后跳转
                const messageEl = document.getElementById("message")!;
                const countdownEl = document.getElementById("countdown")!;

                messageEl.innerHTML = `
                    <div class="unsupported">
                        ⚠️ Your browser's preferred language (${userLang}) is not supported by this site.
                    </div>
                    <p style="margin-top: 1rem;">Redirecting to default language (English)...</p>
                `;

                let seconds = 3;
                countdownEl.textContent = `Redirecting in ${seconds}s...`;

                const timer = setInterval(() => {
                    seconds -= 1;
                    if (seconds > 0) {
                        countdownEl.textContent = `Redirecting in ${seconds}s...`;
                    } else {
                        clearInterval(timer);
                        window.location.replace(DEFAULT_LOCALE);
                    }
                }, 1000);
            }
        </script>
    </body>
</html>
